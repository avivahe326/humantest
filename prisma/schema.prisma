generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id           String             @id @default(cuid())
  email        String             @unique
  password     String
  name         String?
  apiKey       String             @unique
  createdAt    DateTime           @default(now())
  claims       TaskClaim[]
  tasks        Task[]
  feedbacks    Feedback[]
}

model Task {
  id               String     @id @default(cuid())
  title            String     @db.VarChar(200)
  description      String?    @db.Text
  targetUrl        String     @db.VarChar(2000)
  focus            String?    @db.Text
  requirements     Json?
  maxTesters       Int        @default(5)
  estimatedMinutes Int        @default(10)
  status           TaskStatus @default(OPEN)
  webhookUrl       String?    @db.VarChar(2000)
  creatorId        String
  creator          User       @relation(fields: [creatorId], references: [id])
  report           String?    @db.LongText
  reportStatus     String?    @db.VarChar(20)
  repoUrl          String?    @db.VarChar(2000)
  repoBranch       String?    @db.VarChar(200)
  codeFixStatus    String?    @db.VarChar(20)
  codeFixPrUrl     String?    @db.VarChar(2000)
  locale           String?    @db.VarChar(5)
  claimDeadline    DateTime?
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  claims           TaskClaim[]
  feedbacks        Feedback[]

  @@index([status, createdAt])
  @@index([creatorId])
}

model TaskClaim {
  id           String      @id @default(cuid())
  taskId       String
  userId       String
  status       ClaimStatus @default(IN_PROGRESS)
  screenRecUrl String?     @db.VarChar(2000)
  audioUrl     String?     @db.VarChar(2000)
  claimedAt    DateTime    @default(now())
  task         Task        @relation(fields: [taskId], references: [id])
  user         User        @relation(fields: [userId], references: [id])
  feedback     Feedback?

  @@unique([taskId, userId])
  @@index([userId])
}

model Feedback {
  id                  String   @id @default(cuid())
  taskId              String
  claimId             String   @unique
  userId              String
  textFeedback        String?  @db.Text
  screenRecUrl        String?  @db.VarChar(2000)
  audioUrl            String?  @db.VarChar(2000)
  rawData             Json?
  mediaAnalysis       String?  @db.LongText
  mediaAnalysisStatus String?  @db.VarChar(20)
  createdAt           DateTime @default(now())
  task                Task     @relation(fields: [taskId], references: [id])
  claim               TaskClaim @relation(fields: [claimId], references: [id])
  user                User     @relation(fields: [userId], references: [id])
}

enum TaskStatus {
  OPEN
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum ClaimStatus {
  IN_PROGRESS
  SUBMITTED
  ABANDONED
}

model EmailVerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String   @db.VarChar(6)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, code])
  @@index([expiresAt])
}
